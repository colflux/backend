Enum cobertura_IGBP {
  Vegetacion_escasa_o_suelo_desnudo // Tierras con menos del 10% de cobertura vegetal.
  Cultivos // Tierras cubiertas por cultivos temporales o permanentes.
  Matorrales_cerrados // Arbustos <2 m con cobertura superior al 60%.
  Mosaico_de_cultivos_y_vegetacion_natural // Mezcla de cultivos, bosques, matorrales y pastizales donde ningún componente supera el 60%.
  Bosques_latifoliados_caducifolios // Bosques de hoja ancha con pérdida estacional de hojas.
  Bosques_de_coniferas_caducifolias // Bosques de coníferas con pérdida estacional de hojas.
  Bosques_latifoliados_siempreverdes // Bosques de hoja ancha verdes todo el año.
  Bosques_de_coniferas_siempreverdes // Bosques de coníferas verdes todo el año.
  Pastizales // Cobertura herbácea con menos del 10% de árboles y arbustos.
  Bosques_mixtos // Mezcla de tipos forestales donde ninguno supera el 60%.
  Matorrales_abiertos // Arbustos <2 m con cobertura entre 10% y 60%.
  Sabanas // Cobertura arbórea entre 10% y 30%.
  Nieve_y_hielo // Superficies cubiertas por nieve o hielo la mayor parte del año.
  Areas_urbanas_y_construidas // Áreas dominadas por infraestructura construida.
  Cuerpos_de_agua // Océanos, mares, lagos, embalses y ríos.
  Humedales_permanentes // Áreas permanentemente inundadas con vegetación acuática o semiacuática.
  Sabanas_arboladas // Cobertura arbórea entre 30% y 60%.
}

Enum protocolo_cos {
  combustion_seca // Cuantifica directamente el carbono total mediante combustión a alta temperatura.
  perdida_por_ignicion // Estima la materia orgánica por pérdida de peso tras quema controlada y la convierte a carbono mediante un factor.
  oxidacion_humeda // Estima el carbono orgánico mediante oxidación química y cuantificación por titulación.
}

Enum tipo_de_suelo {
  Mineral // Suelo dominado por partículas minerales (arena, limo y arcilla) con bajo contenido de materia orgánica.
  Organico // Suelo con alto contenido de materia orgánica acumulada, generalmente formado en condiciones saturadas de agua.
}



