Enum tipo_disturbio {
  Agricultura // Manejo agrícola de cualquier tipo, incluyendo cultivo, labranza, cosecha, riego, pesticidas, siembra o encalado.
  Sequia // Deficiencia prolongada de agua; sequía hidrológica o climática.
  Fuego // Incendios forestales o quemas controladas.
  Silvicultura // Manejo forestal, aprovechamiento maderero, plantaciones o aplicación de herbicidas.
  Pastoreo // Herbivoría o ramoneo por mamíferos manejados o silvestres.
  Evento_hidrologico // Drenaje, inundación persistente o inundación crónica; excluye tormentas y riego.
  Cambio_en_cobertura_del_suelo // Cambios en uso y cobertura del suelo, invasiones biológicas o expansión urbana/leñosa.
  Plagas_y_enfermedades // Daño causado por plagas, insectos, patógenos, tizones u otras enfermedades.
  Tormenta_o_viento // Tormentas severas, vientos extremos, huracanes, tornados, granizadas o inundaciones asociadas.
  Extremos_de_temperatura // Olas de calor o eventos de heladas.
  Sin_disturbio // No se ha registrado disturbio ni manejo en el sitio.
}
Enum uso_actual {
  Bosque_primario // Bosque nativo que no ha sufrido intervención humana significativa reciente y mantiene su estructura ecológica original.
  Bosque_secundario // Bosque que se ha regenerado naturalmente después de un disturbio.
  Plantacion_forestal // Área forestada artificialmente con una o pocas especies, generalmente con fines productivos.
  Agricultura_intensiva // Terreno destinado al cultivo agrícola anual o permanente, incluyendo fertilización o mecanización.
  Agricultura_tradicional // Terreno destinado al cultivo agrícola anual o permanente.
  Pastura // Área dominada por gramíneas usada para pastoreo.
  Humedal_natural // Ecosistema con suelos saturados o inundados periódicamente.
  Humedal_intervenido // Humedal con alteraciones hidrológicas como drenaje, canalización o compactación.
  Area_protegida // Territorio legalmente designado para la conservación de biodiversidad, servicios ecosistémicos o valores culturales.
  Sistema_agroforestal // Sistema de uso del suelo que integra árboles con cultivos agrícolas y/o ganado.
  Abandonado // Área previamente usada para agricultura o pastura que ya no tiene manejo activo.
  Restauracion_activa // Área en proceso formal de restauración ecológica con intervención humana planificada.
}

Enum estado_actual {
  Intacto // Ecosistema sin señales evidentes de degradación estructural o funcional.
  Ligeramente_degradado // Alteraciones leves sin pérdida significativa de funciones ecológicas.
  Moderadamente_degradado // Reducción clara en biodiversidad, compactación del suelo o cambios hidrológicos parciales.
  Severamente_degradado // Pérdida significativa de cobertura vegetal, erosión visible y alteración fuerte del ciclo hidrológico.
  En_recuperacion_natural // Ecosistema en proceso de regeneración tras disturbio sin intervención intensiva.
  En_restauracion_activa // Ecosistema con intervención planificada que ha alcanzado estabilidad funcional.
  Estable // Sistema que mantiene estructura y función constantes bajo el régimen actual.
  En_transicion // Ecosistema en cambio activo entre estados (ej. pastura → bosque secundario).
}

Table disturbio [headercolor: #2ecc71] {
  // Torres y en pROYECTO
  id int [pk, increment]
  descripcion text
  fecha_inicio date
  fecha_fin date
  incertidumbre_anios int

  tipo tipo_disturbio
  anios_disturbio int
  anios_desde_fin int


  estado_actual estado_actual
}

Enum ecosistema {
  Paramo_seco // Ecosistema altoandino frío con vegetación adaptada a baja humedad y alta radiación.
  Turbera_de_alta_elevacion // Humedal de montaña donde se acumula materia orgánica saturada de agua.
  Bosque_humedo_tropical // Bosque cálido y lluvioso con alta biodiversidad y vegetación densa.
  Bosque_de_niebla // Bosque montano húmedo con presencia frecuente de neblina y alta humedad.
  Bosque_seco_tropical // Bosque cálido con temporada seca marcada y vegetación adaptada a la escasez de agua.
  Sabana_seca // Ecosistema abierto de pastizales y árboles dispersos con baja disponibilidad de agua.
  Sabana_inundable // Sabana que se inunda temporalmente por lluvias o desbordamientos.
  Turbera_de_baja_elevacion // Humedal en zonas bajas con suelos saturados y acumulación de materia orgánica.
  Pantano_cienaga // Humedal de aguas poco profundas con vegetación acuática o semiacuática.
  Lago_superficial // Cuerpo de agua continental poco profundo con interacción directa entre agua, sedimentos y vegetación.
  Manglar // Ecosistema costero tropical con árboles tolerantes a la salinidad e influencia de mareas.
}

Enum microtopografia {
  Hummock // Cojines.
  Hollow // Depresiones húmedas.
  Pool // Charcos, piscinas o mediciones realizadas directamente sobre agua.
  Lawns // Lugares planos.
}


Enum fuente_poder {
  generador_metanol // Generador alimentado con metanol.
  generador_gasolina // Generador alimentado con gasolina.
  solar_mas_generador // Sistema híbrido solar + generador.
  otro // Otra fuente de energía (especificar).
}
