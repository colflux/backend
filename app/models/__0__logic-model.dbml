
Enum escala_monitoreo {
  Bioma // Grandes zonas ecológicas con clima y vegetación dominante (páramo, selva tropical).
  Regional // Conjunto de paisajes con clima y biogeografía similares.
  Ecosistema // Área con estructura y funciones comunes (bosque, turbera, lago).
  Sitio // Conjunto de parcelas o instrumentos en un mismo ecosistema local.
  Parcela // Unidad fija de medición (parcelas de vegetación, collares, sensores).
}

// https://livejaverianaedu-my.sharepoint.com/:x:/r/personal/marian_cabrerap_javeriana_edu_co/_layouts/15/Doc.aspx?sourcedoc=%7B90BECD76-6AE4-4AD5-BE9C-D2681BB1BB21%7D&file=LECC_Metadatos_proyecto_v2.xlsx&action=default&mobileredirect=true 
Table proyecto [headercolor: #e84393] {
  id int [pk, increment]
  codigo varchar
  nombre varchar
  fecha_inicio date
  fecha_fin date
  coordinador varchar
  correo_coordinador varchar
  sitio text
  abreviatura_sitio varchar
  objetivo_general text
  preguntas_principales text
  escala_espacial escala_monitoreo
  numero_sitios_monitoreo int
  estructura_muestreo text
  tipo_diseno text
  objetivo_especifico text
  sitio_id int [ref: > sitio.id]

}

Enum pendiente {
  plano // Superficie con pendiente mínima.
  ondulado_variable // Relieve irregular con pendientes variables.
  valle_fondo // Zona baja del relieve con acumulación.
  pendiente_suave // Pendiente muy baja (<2%).
  pendiente_media // Pendiente moderada (2–5%).
  pendiente_significativa // Pendiente marcada (5–10%).
  pendiente_fuerte // Pendiente pronunciada (>10%).
  cresta_cima // Parte alta o divisoria del relieve.
}

Enum topografia {
  cresta_cima // Parte más alta del relieve; zona de divergencia de escorrentía.
  ladera_superior // Tramo alto de la ladera; drenaje rápido y baja acumulación.
  ladera_media // Tramo intermedio de la ladera; tránsito de agua y sedimentos.
  ladera_inferior // Tramo bajo de la ladera; mayor acumulación de agua y materiales.
  valle_fondo // Zona baja del relieve; acumulación de agua y sedimentos.
  plano // Superficie con pendiente mínima y escasa redistribución lateral.
}

Enum propiedad_tierra {
  publica // Terreno de propiedad del Estado o entidad pública.
  privada // Terreno de propiedad privada o comunitaria no estatal.
}

// Detalle de una unidad de muestreo cuando su tipo es 'transecto'.
Table transecto {
  id int [pk]
  unidad_muestreo_id int [ref: - unidad_muestreo.id] // 1–1
  nombre varchar
  longitud decimal
  separacion_muestreo decimal
  descripcion varchar
}

Table sitio [headercolor: #f1c40f] {
  id int [pk]
  proyecto_id int

  codigo_metadatos varchar
  nombre varchar

  latitud decimal
  longitud decimal
  sistema_referencia int [ref: > sistema_referencia.id] 

  altitud decimal
  pendiente pendiente
  topografia topografia
  uso_actual uso_actual
  propiedad_tierra propiedad_tierra
  invertevido bool // https://livejaverianaedu-my.sharepoint.com/:x:/r/personal/marian_cabrerap_javeriana_edu_co/_layouts/15/Doc.aspx?sourcedoc=%7B08F8B97C-7DC6-48D4-A9FE-3C232F1AE733%7D&file=Suelos_2021.xlsx&action=default&mobileredirect=true 


  municipio varchar [ref: > municipio.id]
  disturbio varchar  [ref: > disturbio.id]
  vegetacion varchar  [ref: > vegetacion.id]
  cobertura varchar  [ref: > cobertura.id]
}

Enum estatus_parcela {
  Activa // En proceso de medición o mantenimiento.
  Inactiva // No se han realizado mediciones recientes pero el sitio existe.
  Abandonada // El sitio no es recuperable o se perdió el marcado.
  Finalizada // Sin proceso de medición o mantenimiento.
}

Enum unidad_de_muestreo {
  Parcela_permanente_cuadrada // Parcela Permanente Cuadrada.
  Parcela_permanente_rectangular // Parcela Permanente Rectangular.
  Parcela_circular // Parcela Circular.
  Transecto_lineal // Transecto Lineal.
  Puntos_de_muestreo_aleatorios // Puntos de Muestreo Aleatorios.
  Conglomerado // Conjunto de subparcelas.
}

// Catálogo de tipos de unidad de muestreo (parcela, transecto, conglomerado, plot).
Table unidad_muestreo_tipo [headercolor: #f1c40f] {
  id int [pk]
  nombre varchar
}

// Unidad a la que se asigna/representa un tratamiento independiente.
// Agrupa una o varias unidades de muestreo (transecto → puntos/plots, o varias parcelas).
Table unidad_experimental [headercolor: #f1c40f] {
  id int [pk]
  nombre varchar
  descripcion text
}

// Lugar/objeto desde el cual se toma la muestra; su tipo sale del catálogo.
Table unidad_muestreo [headercolor: #f1c40f] {
  id int [pk]
  nombre varchar
  tipo_id int [ref: > unidad_muestreo_tipo.id]
  unidad_experimental_id int [ref: > unidad_experimental.id] // 1 experimental → N muestreo
}

// Detalle de una unidad de muestreo cuando su tipo es 'parcela' (dimensiones).
Table parcela [headercolor: #2ecc71] {
  id int [pk]
  unidad_muestreo_id int [ref: - unidad_muestreo.id] // 1–1
  nombre varchar
  medida_largo decimal
  medida_ancho decimal
  descripcion text
}

Enum tipo_monitoreo {
  Biomasa_Aerea
  Biomasa_Subterranea
  Flora
  Rasgos_Funcionales
}

Enum protocolo_biomasa_aerea {
  Alometria_destructiva // Medición física y destructiva de la biomasa.
  Alometria_no_destructiva // Medición de la biomasa a partir de modelos matemáticos.
  LiDAR_terrestre // LiDAR terrestre.
  LiDAR_aerotransportado // LiDAR aerotransportado.
}

Table monitoreo_parcela {
  id int [pk]
  unidad_muestreo_id int

  tipo_monitoreo tipo_monitoreo

  activo boolean
  protocolo protocolo_biomasa_aerea
}

Ref: monitoreo_parcela.unidad_muestreo_id > unidad_muestreo.id


Enum sistema_referencia {
  EPSG_4326 // Sistema geodésico global estándar; coordenadas geográficas en latitud y longitud (WGS84).
  EPSG_4686 // Sistema geodésico oficial de Colombia, compatible con WGS84 (MAGNA-SIRGAS).
  EPSG_4674 // Sistema geodésico regional usado en América del Sur (SIRGAS2000).
  Otro // Sistema de referencia distinto; se debe indicar el código EPSG.
}

Table sistema_referencia {
  id int [pk]
  nombre sistema_referencia
}

Enum clima_koeppen {
  Selva_tropical_lluviosa // Clima cálido y húmedo durante todo el año, sin estación seca definida.
  Monzon_tropical // Clima cálido con estación húmeda intensa y estación seca corta.
  Sabana_tropical // Clima cálido con estación seca bien definida y lluvias estacionales.
  Desierto_IC // Clima extremadamente árido con precipitaciones muy bajas (<250 mm anuales).
  Desierto_IF // Clima árido con inviernos fríos y veranos cálidos.
  Oceanico_de_la_costa_occidental_VC // Clima templado con precipitaciones constantes y veranos moderadamente cálidos.
  Oceanico_de_la_costa_occidental_VF // Clima templado-frío con veranos frescos e inviernos suaves.
  Templado_de_montania_VC // Clima templado de altitud con invierno seco y verano lluvioso.
  Templado_de_montania_VF // Clima de montaña frío con inviernos secos y veranos frescos.
  Continental_humedo // Clima con inviernos fríos y veranos calurosos; lluvias todo el año.
  Continental_de_verano_calido // Clima continental con inviernos fríos y veranos templados a cálidos.
  Continental_seco_VC // Clima continental con estación seca marcada y veranos calurosos.
  Continental_de_verano_calido_2 // Variante continental con veranos templados a cálidos e inviernos fríos.
  Continental_seco_VF // Clima continental con estación seca y veranos frescos.
  Continental_humedo_1 // Clima con inviernos fríos prolongados y veranos moderadamente cálidos.
  Continental_de_verano_calido_3 // Clima continental con invierno seco y verano húmedo.
  Casquete_de_hielo // Clima polar extremo con temperatura media mensual inferior a 0 °C.
  Tundra // Clima polar donde el mes más cálido no supera los 10 °C.
}


Table cobertura [headercolor: #2ecc71] {
  id int [pk]
  cobertura_clc varchar
  cobertura_nombre_comun varchar
  clima_koeppen clima_koeppen
}

