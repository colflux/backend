// ═══════════════════════════════════════════════════════════════════════════
// Muestras de flujo de CO₂ (cámaras cerradas)
//
// Jerarquía de muestreo:
//   unidad experimental (lleva el tratamiento)
//     └─ unidad de muestreo (nombre + tipo: parcela/transecto/conglomerado/plot)
//          └─ anillo            → objeto FIJO instalado en la unidad de muestreo
//               └─ muestra_co2   → evento de medición (cámara conectada al anillo)
//                    └─ submuestra_co2 → las ~4 tomas; aquí vive el valor del flujo
//
// La parcela se deriva del anillo (fijo). La cámara/sensor es equipo MÓVIL:
// una parcela puede tener varios equipos, por eso la cámara no cuelga de la parcela.
// ═══════════════════════════════════════════════════════════════════════════

Enum tipo_unidad_muestreo {
  parcela
  transecto
  conglomerado
  plot
}

Enum condicion_luz {
  dia            // Medición tomada de día.
  noche          // Medición tomada de noche.
  noche_simulada // Noche simulada cubriendo la cámara con una cobija.
}

Enum momento_toma {
  inicio // Lectura al inicio del cierre de la cámara (pendiente por validar).
  final  // Lectura al final del cierre de la cámara (pendiente por validar).
}

Table unidad_medida [headercolor: #9b59b6] {
  id int [pk, increment]
  codigo varchar     // co2_flux_micromol_m2_s
  descripcion varchar
  magnitud varchar   // flujo | concentracion | temperatura | ...
}

Table camara [headercolor: #9b59b6] {
  id int [pk, increment]
  codigo varchar                 // 738, 64
  equipo_id int [ref: > equipo.id] // picarro (Analizador CO₂)
}

Table anillo [headercolor: #9b59b6] {
  id int [pk, increment]
  unidad_muestreo_id int [ref: > unidad_muestreo.id] // fijo en la unidad de muestreo
  diametro decimal
  volumen decimal
}

Table muestra_ambiental [headercolor: #9b59b6] {
  id int [pk, increment]
  fecha date
  hora time
  soil_temp decimal
  air_temp decimal
  atm_press decimal
  relat_humid decimal
  dew_point decimal
  microtopo microtopografia
}

Table muestra_co2 [headercolor: #9b59b6] {
  id int [pk, increment]
  anillo_id int [ref: > anillo.id]   // da la parcela (camino fijo)
  camara_id int [ref: > camara.id]   // sensor/picarro usado (camino móvil)
  fecha date
  muestra_ambiental_id int [ref: > muestra_ambiental.id]
}

Table submuestra_co2 [headercolor: #9b59b6] {
  id int [pk, increment]
  muestra_co2_id int [ref: > muestra_co2.id]
  n_toma int                     // 1..N, variable por dataset (normalmente 4)
  hora time                      // tiempo de la toma
  momento momento_toma           // inicio | final (por validar)
  condicion_luz condicion_luz    // dia | noche | noche_simulada
  valor decimal                  // valor del flujo
  unidad_medida_id int [ref: > unidad_medida.id]
}


